# Supabase project credentials (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key - server-side only, NEVER expose to the client/browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin login (single shared password, no admin accounts table)
ADMIN_PASSWORD=change-me-to-a-strong-password
# Random 32+ char secret used to sign the admin session cookie
ADMIN_SESSION_SECRET=change-me-to-a-long-random-string
